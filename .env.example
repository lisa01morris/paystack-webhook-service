# ═════════════════════════════════════════════════════
# PAYSTACK CONFIGURATION
# ═════════════════════════════════════════════════════
PAYSTACK_SECRET=sk_live_your_secret_key_here

# ═════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═════════════════════════════════════════════════════
PORT=10000
NODE_ENV=production

# ═════════════════════════════════════════════════════
# EMAIL CONFIGURATION (SMTP)
# ═════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@globalpresses.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=info@luckmanworld.icu
BUSINESS_ALERT_EMAIL=info@luckmanworld.icu

# ═════════════════════════════════════════════════════
# SMS CONFIGURATION (Twilio - Optional)
# ═════════════════════════════════════════════════════
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM=+1234567890

# ═════════════════════════════════════════════════════
# DATABASE CONFIGURATION (Optional - for production)
# ═════════════════════════════════════════════════════
DATABASE_URL=mongodb://localhost:27017/paystack_webhooks

# ═════════════════════════════════════════════════════
# LOGGING
# ═════════════════════════════════════════════════════
LOG_LEVEL=info
